# Copy to `.env` and fill in. Do NOT commit a populated .env.

# dev | prod. In dev a bare GROQ_API_KEY is allowed as a fallback so you can
# curl the API without setting an X-Groq-Api-Key header every time.
ENV=dev

# Supabase Postgres connection string (from Project Settings → Database).
# Leave unset to run /healthz only (other routes will 500 without a pool).
DATABASE_URL=postgresql://postgres:<password>@<host>:5432/postgres

# Comma-separated CORS origins.
ALLOWED_ORIGINS=http://localhost:3000

# Optional dev fallback Groq key. In prod, set ENV=prod and this is ignored.
GROQ_API_KEY=
